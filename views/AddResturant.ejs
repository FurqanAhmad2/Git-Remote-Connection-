                                <p class="text-white-50 mb-5">Please enter Resturant Information</p>
    
                                <div class="form-outline form-white mb-4">
                                    <input type="email" id="email" name="email" class="form-control form-control-lg" required/>
                                    <label class="form-label" for="typeEmailX">Email of Resturant</label>
                                </div>
    
                                <div class="form-outline form-white mb-4">
